# =============================================================================
# XOLR STUDIO — Environment Variables
# Version 3.0 — Junio 2026
# Copiar a .env y completar los valores antes de ejecutar la aplicación.
# NUNCA commitear el archivo .env con valores reales.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_NAME="Xolr Studio"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://xolrstudio.com
APP_TIMEZONE=America/Mexico_City

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# -----------------------------------------------------------------------------
# Base de Datos — MySQL 8
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=xolr_studio
DB_USERNAME=xolr
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Cache — Redis 7
# -----------------------------------------------------------------------------
CACHE_STORE=redis
CACHE_PREFIX=xolr_

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Sesiones
# -----------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.xolrstudio.com

# -----------------------------------------------------------------------------
# Colas — Laravel Horizon + Redis
# Workers: default, renders, audio, lipsync, publishing, notifications
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=redis

# -----------------------------------------------------------------------------
# WebSockets — Laravel Reverb
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=xolrstudio
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# -----------------------------------------------------------------------------
# Almacenamiento — Cloudflare R2 (compatible con S3 SDK)
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=xolr-studio-assets
AWS_URL=https://assets.xolrstudio.com
AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

CLOUDFLARE_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# Búsqueda — MeiliSearch
# -----------------------------------------------------------------------------
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# -----------------------------------------------------------------------------
# Email — Resend (transaccional confiable)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@xolrstudio.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Render Farm — RunPod Serverless
# Cada endpoint = worker diferente en RunPod
# -----------------------------------------------------------------------------
RUNPOD_API_KEY=

# FLUX.1 Schnell (Draft) + FLUX.1 Dev (Standard) — ComfyUI
RUNPOD_ENDPOINT_IMAGE=

# WAN 2.1 / CogVideoX — Generación de video
RUNPOD_ENDPOINT_VIDEO=

# RealESRGAN 4x — Upscaling para renders Final tier
RUNPOD_ENDPOINT_UPSCALE=

# Wav2Lip / LatentSync — Lip sync calidad Draft (~$0.004/seg)
RUNPOD_ENDPOINT_LIPSYNC=

# MusicGen (Meta) — Generación de música open source (fallback de Suno)
RUNPOD_ENDPOINT_MUSICGEN=

# AudioGen (Meta) — Ambient sounds y SFX (fallback de ElevenLabs)
RUNPOD_ENDPOINT_AUDIOGEN=

# Secret para verificar HMAC de webhooks de RunPod en /api/webhooks/runpod
RUNPOD_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Audio — ElevenLabs
# Usado para: TTS, Voice Cloning, Sound Effects
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_MODEL=eleven_multilingual_v2

# -----------------------------------------------------------------------------
# Lip Sync — D-ID (calidad 'production', ~$0.015/seg)
# Recomendado para Strange Light diálogos
# -----------------------------------------------------------------------------
DID_API_KEY=
DID_API_URL=https://api.d-id.com

# -----------------------------------------------------------------------------
# Lip Sync — HeyGen (calidad 'premium', ~$0.025/seg)
# Recomendado para Home del Valle broker videos
# -----------------------------------------------------------------------------
HEYGEN_API_KEY=
HEYGEN_API_URL=https://api.heygen.com

# -----------------------------------------------------------------------------
# Música — Suno API (requiere plan Pro para licencia comercial)
# Fallback: MusicGen en RunPod (RUNPOD_ENDPOINT_MUSICGEN)
# -----------------------------------------------------------------------------
SUNO_API_KEY=
SUNO_PLAN=pro

# -----------------------------------------------------------------------------
# Subtítulos — OpenAI Whisper
# IMPORTANTE: Esta key es SOLO para Whisper. No usar para Claude.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# IA Creativa — Claude (Anthropic)
# Usado en: Script Generator, AI Director, Ghost Director, captions, SEO, pricing
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8192

# -----------------------------------------------------------------------------
# Publicación — YouTube Data API v3 + YouTube Analytics API
# OAuth2: el usuario conecta su canal desde /settings/integrations
# -----------------------------------------------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://xolrstudio.com/oauth/youtube/callback

# -----------------------------------------------------------------------------
# Publicación — Instagram Graph API
# OAuth2: el usuario conecta su cuenta desde /settings/integrations
# -----------------------------------------------------------------------------
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://xolrstudio.com/oauth/instagram/callback

# -----------------------------------------------------------------------------
# Notion Sync (unidireccional: Xolr → Notion, cada hora)
# -----------------------------------------------------------------------------
NOTION_API_KEY=
NOTION_WORKSPACE_ID=

# -----------------------------------------------------------------------------
# Presupuesto y Alertas de Costo
# -----------------------------------------------------------------------------
RENDER_BUDGET_MONTHLY_USD=200
RENDER_BUDGET_ALERT_THRESHOLD=0.80
RENDER_BUDGET_DAILY_USD=10

# -----------------------------------------------------------------------------
# Auto-Post y Analytics Inverso (Cron schedules)
# -----------------------------------------------------------------------------
AUTOPOST_CHECK_INTERVAL_MINUTES=5
ANALYTICS_SYNC_HOUR=3

# -----------------------------------------------------------------------------
# Laravel Pulse — Monitoreo de la aplicación
# Dashboard en /pulse (acceso: roles owner + admin)
# -----------------------------------------------------------------------------
PULSE_ENABLED=true

# -----------------------------------------------------------------------------
# Multi-Tenant (Xolr OS — Fase 20, mantener false hasta entonces)
# -----------------------------------------------------------------------------
MULTI_TENANT_ENABLED=false

# -----------------------------------------------------------------------------
# Vite — Variables expuestas al frontend Vue
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
